# Example environment configuration.
#
# Copy this file to `.env` and adjust as needed:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed — it is where real secrets go.
# Every value below has a safe default in `shl_recommender/config.py`; this file
# documents what exists and what a deployment is likely to override. Application
# settings are read with the `SHL_` prefix; the model provider key is read by the
# LLM library directly and so has no prefix.

# ---------------------------------------------------------------------------
# Model provider credential (SECRET — do not commit a real value)
# ---------------------------------------------------------------------------
# The service talks to the language model through LiteLLM, which reads the
# provider's key from the environment under the provider's own variable name.
# The default model is Google Gemini, whose key variable is GEMINI_API_KEY. If you
# point SHL_LLM_MODEL at a different provider, set that provider's key instead
# (for example OPENAI_API_KEY, GROQ_API_KEY, OPENROUTER_API_KEY).
GEMINI_API_KEY=

# Optional secondary key, used ONLY as failover. The free Gemini tier has a small
# daily/per-minute quota; when the primary key above is rate-limited (HTTP 429) or
# missing/rejected, the client retries the same call once with this key so a burst
# does not force every turn onto the deterministic fallback wording. Leave unset for
# normal single-key operation. (Two free keys multiply, not remove, the daily cap;
# for guaranteed headroom use a billed key or a higher-limit provider.)
SHL_GEMINI_API_KEY_FALLBACK=

# Optional CROSS-PROVIDER fallback model, tried last — only after the primary model
# (and its fallback key) are both rate-limited or unavailable. A wholly different
# provider so a provider-wide outage or daily-quota exhaustion still leaves a working
# model. Its key is read by the provider from its own environment variable below. A
# generous free tier here (e.g. Groq) effectively removes the quota problem.
SHL_LLM_FALLBACK_MODEL=
# Key for the cross-provider fallback, if it is a Groq model (read by LiteLLM directly,
# no prefix). Set the matching variable if you point the fallback at another provider.
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Language model
# ---------------------------------------------------------------------------
# Provider/model in LiteLLM's "provider/model" form. Swapping providers is a
# configuration change only — no code depends on a specific vendor.
SHL_LLM_MODEL=gemini/gemini-2.5-flash
# Hard timeout (seconds) on a single model call. The service must stay well within
# the evaluator's per-turn budget, so a slow call is cut and the deterministic
# fallback takes over rather than hanging the request.
SHL_LLM_TIMEOUT_SECONDS=20

# ---------------------------------------------------------------------------
# Conversation policy
# ---------------------------------------------------------------------------
# How many clarifying questions to allow before committing to a first shortlist.
SHL_MAX_CLARIFYING_QUESTIONS=2
# Total user+assistant messages the evaluator allows; as we approach it we prefer
# committing over asking again.
SHL_TURN_CAP=8
# Hard cap on a committed shortlist (the contract allows 1..10).
SHL_MAX_RECOMMENDATIONS=10

# ---------------------------------------------------------------------------
# Response shape
# ---------------------------------------------------------------------------
# On non-commit turns the recommendation field is JSON null by default (matching
# the sample conversations). Set to false to emit an empty list [] instead.
SHL_EMPTY_RECOMMENDATIONS_AS_NULL=true

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# Minimum log level: DEBUG | INFO | WARNING | ERROR.
SHL_LOG_LEVEL=INFO
# Log format: "json" for a deployed host that ships structured logs, "console" for
# a readable local run.
SHL_LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Deploy metadata (optional; usually injected by the host)
# ---------------------------------------------------------------------------
# The running build's git commit, surfaced in the health report so an instance can
# be tied back to a specific build. Most hosts set one of these automatically
# (RENDER_GIT_COMMIT, RAILWAY_GIT_COMMIT_SHA, ...); set SHL_GIT_COMMIT by hand only
# when the platform does not.
# SHL_GIT_COMMIT=
