# Keep the image small and never ship secrets or dev-only files.

# Secrets and local env
.env
.env.*
!.env.example

# Python caches and build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Local tooling / model cache (the image rebuilds the model at build time)
.model_cache/
.veris/

# Tests and docs are not needed at runtime
tests/
docs/
*.md
!README.md

# VCS and editor
.git/
.gitignore
.vscode/
.idea/
